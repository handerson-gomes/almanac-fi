{
  "name": "@almanac-fi/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "almanac-fi-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "node --conditions=development --import tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit --project tsconfig.check.json"
  },
  "dependencies": {
    "@almanac-fi/core": "workspace:*"
  }
}
